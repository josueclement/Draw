<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Custom tool glyphs for UML items PhosphorIconsAvalonia has no match for.
      Authored in a 24x24 space; PathIcon fills with Foreground. Outline shapes use
      the even-odd rule (F0: outer ring minus inner). Relationship glyphs mirror the
      end-caps produced by Rendering/ConnectorDecorationBuilder (diamond/triangle/arrow,
      hollow vs filled, solid vs dashed) so the menu icon reads like the drawn connector.
    -->

    <!-- Shapes (outline) -->
    <GeometryGroup x:Key="ToolIcon.Ellipse" FillRule="EvenOdd">
        <EllipseGeometry Rect="1,5,22,14" />
        <EllipseGeometry Rect="3,7,18,10" />
    </GeometryGroup>
    <StreamGeometry x:Key="ToolIcon.RoundedRectangle">F0 M6,5 L18,5 A4,4 0 0 1 22,9 L22,15 A4,4 0 0 1 18,19 L6,19 A4,4 0 0 1 2,15 L2,9 A4,4 0 0 1 6,5 Z M7,7 L17,7 A3,3 0 0 1 20,10 L20,14 A3,3 0 0 1 17,17 L7,17 A3,3 0 0 1 4,14 L4,10 A3,3 0 0 1 7,7 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Trapezoid">F0 M7,6 L17,6 L21,18 L3,18 Z M9,8 L15,8 L18.5,16 L5.5,16 Z</StreamGeometry>
    <!-- Note: a folded-corner sheet. Body silhouette with the dog-ear cut out (even-odd hole). -->
    <StreamGeometry x:Key="ToolIcon.Note">F0 M4,3 L14,3 L20,9 L20,21 L4,21 Z M14,3 L14,9 L20,9 Z</StreamGeometry>

    <!-- Geometric shapes (filled silhouettes, mirroring ShapeOutline.GetPolygon / CloudCurve). -->
    <StreamGeometry x:Key="ToolIcon.Hexagon">M7,2 L17,2 L22,12 L17,22 L7,22 L2,12 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Pentagon">M12,2 L21.51,8.91 L17.88,20.09 L6.12,20.09 L2.49,8.91 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Octagon">M21.24,15.83 L15.83,21.24 L8.17,21.24 L2.76,15.83 L2.76,8.17 L8.17,2.76 L15.83,2.76 L21.24,8.17 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Star">M12,2 L14.25,8.91 L21.51,8.91 L15.63,13.18 L17.88,20.09 L12,15.82 L6.12,20.09 L8.37,13.18 L2.49,8.91 L9.75,8.91 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Cross">M9,3 L15,3 L15,9 L21,9 L21,15 L15,15 L15,21 L9,21 L9,15 L3,15 L3,9 L9,9 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Cloud">M12,6.96 Q16.44,4.31 16.36,9.48 Q20.88,12 16.36,14.52 Q16.44,19.69 12,17.04 Q7.56,19.69 7.64,14.52 Q3.12,12 7.64,9.48 Q7.56,4.31 12,6.96 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Callout">M3,3 L21,3 L21,14 L11,14 L7,20 L8,14 L3,14 Z</StreamGeometry>

    <!-- Arrange: distribute glyphs (three evenly-spaced bars). Phosphor has align icons but no
         distribute equivalents, so author them here. Horizontal = bars spread along X (vertical bars);
         vertical = bars spread along Y (horizontal bars). -->
    <GeometryGroup x:Key="ToolIcon.DistributeHorizontal">
        <RectangleGeometry Rect="3,5,3,14" />
        <RectangleGeometry Rect="10.5,5,3,14" />
        <RectangleGeometry Rect="18,5,3,14" />
    </GeometryGroup>
    <GeometryGroup x:Key="ToolIcon.DistributeVertical">
        <RectangleGeometry Rect="5,3,14,3" />
        <RectangleGeometry Rect="5,10.5,14,3" />
        <RectangleGeometry Rect="5,18,14,3" />
    </GeometryGroup>

    <!-- Space connections: a shape edge (vertical bar) with three evenly-spaced connectors leaving it. -->
    <GeometryGroup x:Key="ToolIcon.SpaceConnections">
        <RectangleGeometry Rect="4,3,2,18" />
        <RectangleGeometry Rect="6,6.5,14,2" />
        <RectangleGeometry Rect="6,11,14,2" />
        <RectangleGeometry Rect="6,15.5,14,2" />
    </GeometryGroup>

    <!-- Merge connections: a shape edge (vertical bar) with three connectors converging to one centred
         point on it. Visual inverse of ToolIcon.SpaceConnections. -->
    <GeometryGroup x:Key="ToolIcon.MergeConnections">
        <RectangleGeometry Rect="4,3,2,18" />
        <StreamGeometry>M20,5 L20,7 L6,13 L6,11 Z</StreamGeometry>
        <RectangleGeometry Rect="6,11,14,2" />
        <StreamGeometry>M20,17 L20,19 L6,13 L6,11 Z</StreamGeometry>
    </GeometryGroup>

    <!-- Styles: "no fill" — a square frame crossed by a diagonal slash (NonZero so the slash unions
         over the frame rather than punching holes). -->
    <GeometryGroup x:Key="ToolIcon.NoFill" FillRule="NonZero">
        <RectangleGeometry Rect="3,3,18,2" />
        <RectangleGeometry Rect="3,19,18,2" />
        <RectangleGeometry Rect="3,3,2,18" />
        <RectangleGeometry Rect="19,3,2,18" />
        <StreamGeometry>M3,18.5 L5.5,21 L21,5.5 L18.5,3 Z</StreamGeometry>
    </GeometryGroup>

    <!-- Order (stacking): a filled object square plus a direction arrow; the "to front/back" glyphs
         add a full-width bar that the arrow points to (the very top / very bottom of the stack). -->
    <GeometryGroup x:Key="ToolIcon.BringForward" FillRule="NonZero">
        <RectangleGeometry Rect="7,12,10,9" />
        <StreamGeometry>M12,2 L18,8 L14,8 L14,11 L10,11 L10,8 L6,8 Z</StreamGeometry>
    </GeometryGroup>
    <GeometryGroup x:Key="ToolIcon.SendBackward" FillRule="NonZero">
        <RectangleGeometry Rect="7,3,10,9" />
        <StreamGeometry>M12,22 L18,16 L14,16 L14,13 L10,13 L10,16 L6,16 Z</StreamGeometry>
    </GeometryGroup>
    <GeometryGroup x:Key="ToolIcon.BringToFront" FillRule="NonZero">
        <RectangleGeometry Rect="4,2,16,2" />
        <RectangleGeometry Rect="7,14,10,7" />
        <StreamGeometry>M12,5 L18,11 L14,11 L14,13 L10,13 L10,11 L6,11 Z</StreamGeometry>
    </GeometryGroup>
    <GeometryGroup x:Key="ToolIcon.SendToBack" FillRule="NonZero">
        <RectangleGeometry Rect="4,20,16,2" />
        <RectangleGeometry Rect="7,3,10,7" />
        <StreamGeometry>M12,19 L18,13 L14,13 L14,11 L10,11 L10,13 L6,13 Z</StreamGeometry>
    </GeometryGroup>

    <!-- Class diagram: interface lollipop (provided-interface circle on a stem) -->
    <GeometryGroup x:Key="ToolIcon.Interface" FillRule="EvenOdd">
        <EllipseGeometry Rect="8,3,8,8" />
        <EllipseGeometry Rect="10,5,4,4" />
        <RectangleGeometry Rect="11,11,2,10" />
    </GeometryGroup>

    <!-- Relationships (mirror ConnectorDecorationBuilder.Describe) -->
    <StreamGeometry x:Key="ToolIcon.Association">M2,11.2 L22,11.2 L22,12.8 L2,12.8 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.DirectedAssociation">M2,11.2 L15,11.2 L15,12.8 L2,12.8 Z M22,12 L15,8 L17.5,12 L15,16 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Aggregation">F0 M2,12 L7,7.5 L12,12 L7,16.5 Z M4.5,12 L7,9.8 L9.5,12 L7,14.2 Z M12,11.2 L22,11.2 L22,12.8 L12,12.8 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Composition">M2,12 L7,7.5 L12,12 L7,16.5 Z M12,11.2 L22,11.2 L22,12.8 L12,12.8 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Generalization">F0 M22,12 L14.5,7 L14.5,17 Z M19.2,12 L16.2,9.2 L16.2,14.8 Z M2,11.2 L14.5,11.2 L14.5,12.8 L2,12.8 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Realization">F0 M22,12 L14.5,7 L14.5,17 Z M19.2,12 L16.2,9.2 L16.2,14.8 Z M2,11.2 L6,11.2 L6,12.8 L2,12.8 Z M8.5,11.2 L12.8,11.2 L12.8,12.8 L8.5,12.8 Z</StreamGeometry>
    <StreamGeometry x:Key="ToolIcon.Dependency">M22,12 L15,8 L17.5,12 L15,16 Z M2,11.2 L6,11.2 L6,12.8 L2,12.8 Z M8.5,11.2 L12.8,11.2 L12.8,12.8 L8.5,12.8 Z</StreamGeometry>

</ResourceDictionary>
