<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Draw.App.ViewModels"
        xmlns:v="using:Draw.App.Views"
        xmlns:ribbon="using:Carbon.Avalonia.Desktop.Controls.Ribbon"
        xmlns:dialog="using:Carbon.Avalonia.Desktop.Controls.ContentDialog"
        xmlns:pia="using:PhosphorIconsAvalonia.Markup"
        xmlns:nodes="using:Draw.Model.Nodes"
        xmlns:rel="using:Draw.Model.Connectors"
        xmlns:layout="using:Draw.Diagramming.Layout"
        x:Class="Draw.App.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="{Binding Title}"
        Width="1200" Height="780"
        Background="{DynamicResource CarbonBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <!-- Keyboard shortcuts are not declared here: all gestures and multi-key chords come from the
         JSON keymap, dispatched at the window level in code-behind (see ChordInputDispatcher). -->

    <Window.Resources>
        <!-- Category tool menus opened by keyboard shortcuts (default Shift+S / Shift+C). Items are static
             (icons reuse the ribbon's markup; headers carry _access-key letters); the shared arm command is
             assigned per item in code-behind by CommandParameter type (see WireToolMenu), and the menu is
             opened at the cursor on the active canvas (see DiagramView.OpenToolMenu). -->
        <ContextMenu x:Key="ShapesToolMenu">
            <MenuItem Header="_Standard">
                <MenuItem Header="_Rectangle" CommandParameter="{x:Static nodes:ShapeKind.Rectangle}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=rectangle}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="R_ounded rectangle" CommandParameter="{x:Static nodes:ShapeKind.RoundedRectangle}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.RoundedRectangle}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Ellipse" CommandParameter="{x:Static nodes:ShapeKind.Ellipse}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Ellipse}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Circle" CommandParameter="{x:Static nodes:ShapeKind.Circle}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=circle}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Diamond" CommandParameter="{x:Static nodes:ShapeKind.Diamond}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=diamond}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Parallelogram" CommandParameter="{x:Static nodes:ShapeKind.Parallelogram}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=parallelogram}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Trapezoid" CommandParameter="{x:Static nodes:ShapeKind.Trapezoid}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Trapezoid}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Tr_iangle" CommandParameter="{x:Static nodes:ShapeKind.Triangle}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=triangle}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_UML">
                <MenuItem Header="_Note" CommandParameter="{x:Static nodes:ShapeKind.Note}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Note}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Class" CommandParameter="{x:Static nodes:ClassNodeKind.Class}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=square_split_horizontal}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Interface" CommandParameter="{x:Static nodes:ClassNodeKind.Interface}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Interface}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Enum" CommandParameter="{x:Static nodes:ClassNodeKind.Enum}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=list_numbers}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Actor" CommandParameter="{x:Static vm:UseCaseNodeKind.Actor}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=user}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Use case" CommandParameter="{x:Static vm:UseCaseNodeKind.UseCase}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Ellipse}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_System boundary" CommandParameter="{x:Static vm:UseCaseNodeKind.SystemBoundary}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=bounding_box}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_ER">
                <MenuItem Header="_Table" Tag="entity">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=table}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </ContextMenu>

        <ContextMenu x:Key="ConnectorsToolMenu">
            <MenuItem Header="_Standard">
                <MenuItem Header="_Association" CommandParameter="{x:Static rel:RelationshipKind.Association}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Association}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Directed association" CommandParameter="{x:Static rel:RelationshipKind.DirectedAssociation}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.DirectedAssociation}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_UML">
                <MenuItem Header="_Aggregation" CommandParameter="{x:Static rel:RelationshipKind.Aggregation}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Aggregation}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Composition" CommandParameter="{x:Static rel:RelationshipKind.Composition}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Composition}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Generalization" CommandParameter="{x:Static rel:RelationshipKind.Generalization}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Generalization}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Realization" CommandParameter="{x:Static rel:RelationshipKind.Realization}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Realization}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Dependency" CommandParameter="{x:Static rel:RelationshipKind.Dependency}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Dependency}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Include" CommandParameter="{x:Static rel:RelationshipKind.Include}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Dependency}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Extend" CommandParameter="{x:Static rel:RelationshipKind.Extend}">
                    <MenuItem.Icon><PathIcon Data="{StaticResource ToolIcon.Dependency}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_ER">
                <MenuItem Header="_Relationship" CommandParameter="{x:Static rel:RelationshipKind.Relationship}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=line_segment}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </ContextMenu>
    </Window.Resources>

    <!-- Grid wrapper hosts the full-window ContentDialog overlay above the editor chrome. -->
    <Grid>
    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New document" Command="{Binding NewCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=file_plus}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Open…" Command="{Binding OpenCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=folder_open}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="OpenRecentMenu" Header="Open _Recent" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                    <MenuItem.Styles>
                        <!-- Target only the generated child items, not the "Open Recent" container itself.
                             A bare "MenuItem > MenuItem" also matches this container (it is a child of the
                             File MenuItem), which would bind the string-typed OpenRecentCommand to it with the
                             ShellViewModel as parameter and throw when the File menu opens. -->
                        <Style Selector="MenuItem#OpenRecentMenu > MenuItem">
                            <Setter Property="Command" Value="{Binding $parent[Menu].((vm:ShellViewModel)DataContext).OpenRecentCommand}" />
                            <Setter Property="CommandParameter" Value="{ReflectionBinding}" />
                        </Style>
                    </MenuItem.Styles>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=floppy_disk}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Save _As…" Command="{Binding SaveAsCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=floppy_disk_back}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="E_xport" IsEnabled="{Binding HasActiveDocument}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=export}" Width="16" Height="16" /></MenuItem.Icon>
                    <MenuItem Header="Export _Image…" Command="{Binding ExportImageCommand}">
                        <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=image}" Width="16" Height="16" /></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Export _SVG…" Command="{Binding ExportSvgCommand}">
                        <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=file_svg}" Width="16" Height="16" /></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_Copy as Image" Command="{Binding CopyImageCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=copy}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Close" Command="{Binding CloseDocumentCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=x}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="E_xit" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="{Binding UndoCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=arrow_counter_clockwise}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Redo" Command="{Binding RedoCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=arrow_clockwise}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Cu_t" Command="{Binding CutCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=scissors}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Copy" Command="{Binding CopyCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=copy}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Paste" Command="{Binding PasteCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=clipboard}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="D_uplicate" Command="{Binding DuplicateCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=copy_simple}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Insert _Image…" Command="{Binding InsertImageCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=image}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Delete" Command="{Binding DeleteCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=trash}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Theme" Command="{Binding ToggleThemeCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=moon}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
                <!-- Checkable; OneWay IsChecked reflects state regardless of whether MenuItem self-toggles. -->
                <MenuItem Header="_Properties Panel" ToggleType="CheckBox"
                          IsChecked="{Binding IsInspectorOpen}"
                          Command="{Binding ToggleInspectorCommand}">
                    <MenuItem.Icon><PathIcon Data="{pia:IconGeometry Icon=sidebar}" Width="16" Height="16" /></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Ribbon: replaces the former top toolbar and left tool palette. Tool dropdown items carry their
             CommandParameter (kind) here; their shared Command is assigned in code-behind because Carbon's
             RibbonMenuItem is a plain AvaloniaObject with no DataContext to bind against. -->
        <ribbon:Ribbon x:Name="MainRibbon" DockPanel.Dock="Top">
            <ribbon:RibbonTab Header="Home">
                <ribbon:RibbonGroup Header="File">
                    <ribbon:RibbonButton Header="New document" Command="{Binding NewCommand}" IconData="{pia:IconGeometry Icon=file_plus}" />
                    <ribbon:RibbonButton Header="Open" Command="{Binding OpenCommand}" IconData="{pia:IconGeometry Icon=folder_open}" />
                    <ribbon:RibbonButton Header="Save" Command="{Binding SaveCommand}" IconData="{pia:IconGeometry Icon=floppy_disk}" />
                    <ribbon:RibbonButton Header="Save As" Command="{Binding SaveAsCommand}" IconData="{pia:IconGeometry Icon=floppy_disk_back}" />
                    <ribbon:RibbonButton Header="Close" Command="{Binding CloseDocumentCommand}" IconData="{pia:IconGeometry Icon=x}" />
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="Edit">
                    <ribbon:RibbonButton Header="Undo" Command="{Binding UndoCommand}" IconData="{pia:IconGeometry Icon=arrow_counter_clockwise}" />
                    <ribbon:RibbonButton Header="Redo" Command="{Binding RedoCommand}" IconData="{pia:IconGeometry Icon=arrow_clockwise}" />
                    <ribbon:RibbonButton Header="Cut" Command="{Binding CutCommand}" IconData="{pia:IconGeometry Icon=scissors}" />
                    <ribbon:RibbonButton Header="Copy" Command="{Binding CopyCommand}" IconData="{pia:IconGeometry Icon=copy}" />
                    <ribbon:RibbonButton Header="Paste" Command="{Binding PasteCommand}" IconData="{pia:IconGeometry Icon=clipboard}" />
                    <ribbon:RibbonButton Header="Duplicate" Command="{Binding DuplicateCommand}" IconData="{pia:IconGeometry Icon=copy_simple}" />
                    <ribbon:RibbonButton Header="Delete" Command="{Binding DeleteCommand}" IconData="{pia:IconGeometry Icon=trash}" />
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="Export">
                    <ribbon:RibbonButton Header="Image" Command="{Binding ExportImageCommand}" IconData="{pia:IconGeometry Icon=image}" />
                    <ribbon:RibbonButton Header="SVG" Command="{Binding ExportSvgCommand}" IconData="{pia:IconGeometry Icon=file_svg}" />
                    <ribbon:RibbonButton Header="Copy image" Command="{Binding CopyImageCommand}" IconData="{pia:IconGeometry Icon=copy}" />
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>

            <ribbon:RibbonTab Header="Insert">
                <ribbon:RibbonGroup Header="Common">
                    <ribbon:RibbonDropDownButton x:Name="ShapesDropDown" Header="{Binding Toolbox.ShapesHeader}" IconData="{pia:IconGeometry Icon=shapes}">
                        <ribbon:RibbonMenuItem Header="Rectangle" CommandParameter="{x:Static nodes:ShapeKind.Rectangle}" IconData="{pia:IconGeometry Icon=rectangle}" />
                        <ribbon:RibbonMenuItem Header="Rounded rectangle" CommandParameter="{x:Static nodes:ShapeKind.RoundedRectangle}" IconData="{StaticResource ToolIcon.RoundedRectangle}" />
                        <ribbon:RibbonMenuItem Header="Ellipse" CommandParameter="{x:Static nodes:ShapeKind.Ellipse}" IconData="{StaticResource ToolIcon.Ellipse}" />
                        <ribbon:RibbonMenuItem Header="Circle" CommandParameter="{x:Static nodes:ShapeKind.Circle}" IconData="{pia:IconGeometry Icon=circle}" />
                        <ribbon:RibbonMenuItem Header="Diamond" CommandParameter="{x:Static nodes:ShapeKind.Diamond}" IconData="{pia:IconGeometry Icon=diamond}" />
                        <ribbon:RibbonMenuItem Header="Parallelogram" CommandParameter="{x:Static nodes:ShapeKind.Parallelogram}" IconData="{pia:IconGeometry Icon=parallelogram}" />
                        <ribbon:RibbonMenuItem Header="Trapezoid" CommandParameter="{x:Static nodes:ShapeKind.Trapezoid}" IconData="{StaticResource ToolIcon.Trapezoid}" />
                        <ribbon:RibbonMenuItem Header="Triangle" CommandParameter="{x:Static nodes:ShapeKind.Triangle}" IconData="{pia:IconGeometry Icon=triangle}" />
                    </ribbon:RibbonDropDownButton>
                    <ribbon:RibbonDropDownButton x:Name="CommonConnectorsDropDown" Header="{Binding Toolbox.CommonConnectorsHeader}" IconData="{pia:IconGeometry Icon=line_segment}">
                        <ribbon:RibbonMenuItem Header="Association" CommandParameter="{x:Static rel:RelationshipKind.Association}" IconData="{StaticResource ToolIcon.Association}" />
                        <ribbon:RibbonMenuItem Header="Directed association" CommandParameter="{x:Static rel:RelationshipKind.DirectedAssociation}" IconData="{StaticResource ToolIcon.DirectedAssociation}" />
                    </ribbon:RibbonDropDownButton>
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="UML">
                    <ribbon:RibbonDropDownButton x:Name="ClassDropDown" Header="{Binding Toolbox.ClassHeader}" IconData="{pia:IconGeometry Icon=square_split_horizontal}">
                        <ribbon:RibbonMenuItem Header="Class" CommandParameter="{x:Static nodes:ClassNodeKind.Class}" IconData="{pia:IconGeometry Icon=square_split_horizontal}" />
                        <ribbon:RibbonMenuItem Header="Interface" CommandParameter="{x:Static nodes:ClassNodeKind.Interface}" IconData="{StaticResource ToolIcon.Interface}" />
                        <ribbon:RibbonMenuItem Header="Enum" CommandParameter="{x:Static nodes:ClassNodeKind.Enum}" IconData="{pia:IconGeometry Icon=list_numbers}" />
                    </ribbon:RibbonDropDownButton>
                    <ribbon:RibbonDropDownButton x:Name="UseCaseDropDown" Header="{Binding Toolbox.UseCaseHeader}" IconData="{pia:IconGeometry Icon=user}">
                        <ribbon:RibbonMenuItem Header="Actor" CommandParameter="{x:Static vm:UseCaseNodeKind.Actor}" IconData="{pia:IconGeometry Icon=user}" />
                        <ribbon:RibbonMenuItem Header="Use case" CommandParameter="{x:Static vm:UseCaseNodeKind.UseCase}" IconData="{StaticResource ToolIcon.Ellipse}" />
                        <ribbon:RibbonMenuItem Header="System boundary" CommandParameter="{x:Static vm:UseCaseNodeKind.SystemBoundary}" IconData="{pia:IconGeometry Icon=bounding_box}" />
                    </ribbon:RibbonDropDownButton>
                    <ribbon:RibbonDropDownButton x:Name="UmlConnectorsDropDown" Header="{Binding Toolbox.UmlConnectorsHeader}" IconData="{pia:IconGeometry Icon=line_segment}">
                        <ribbon:RibbonMenuItem Header="Aggregation" CommandParameter="{x:Static rel:RelationshipKind.Aggregation}" IconData="{StaticResource ToolIcon.Aggregation}" />
                        <ribbon:RibbonMenuItem Header="Composition" CommandParameter="{x:Static rel:RelationshipKind.Composition}" IconData="{StaticResource ToolIcon.Composition}" />
                        <ribbon:RibbonMenuItem Header="Generalization" CommandParameter="{x:Static rel:RelationshipKind.Generalization}" IconData="{StaticResource ToolIcon.Generalization}" />
                        <ribbon:RibbonMenuItem Header="Realization" CommandParameter="{x:Static rel:RelationshipKind.Realization}" IconData="{StaticResource ToolIcon.Realization}" />
                        <ribbon:RibbonMenuItem Header="Dependency" CommandParameter="{x:Static rel:RelationshipKind.Dependency}" IconData="{StaticResource ToolIcon.Dependency}" />
                        <ribbon:RibbonMenuItem Header="Include" CommandParameter="{x:Static rel:RelationshipKind.Include}" IconData="{StaticResource ToolIcon.Dependency}" />
                        <ribbon:RibbonMenuItem Header="Extend" CommandParameter="{x:Static rel:RelationshipKind.Extend}" IconData="{StaticResource ToolIcon.Dependency}" />
                    </ribbon:RibbonDropDownButton>
                    <ribbon:RibbonButton Header="Note" Command="{Binding Toolbox.SelectShapeToolCommand}" CommandParameter="{x:Static nodes:ShapeKind.Note}" IconData="{StaticResource ToolIcon.Note}" />
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="ER">
                    <ribbon:RibbonButton Header="Table" Command="{Binding Toolbox.SelectEntityToolCommand}" IconData="{pia:IconGeometry Icon=table}" />
                    <ribbon:RibbonButton Header="Relationship" Command="{Binding Toolbox.SelectConnectorToolCommand}" CommandParameter="{x:Static rel:RelationshipKind.Relationship}" IconData="{pia:IconGeometry Icon=line_segment}" />
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="Image">
                    <ribbon:RibbonButton Header="Insert image" Command="{Binding InsertImageCommand}" IconData="{pia:IconGeometry Icon=image}" />
                </ribbon:RibbonGroup>
                <!-- Quick style palette: theme-aware pastel swatches (one click recolours fill+stroke+text on
                     the selection) plus Reset and No-fill. Enabled only with a selection. -->
                <ribbon:RibbonGroup Header="Styles" IsEnabled="{Binding ActiveDocument.HasSelection}">
                    <ItemsControl ItemsSource="{Binding StylePalette.Swatches}" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:StyleSwatchViewModel">
                                <Button Width="26" Height="26" Margin="1" Padding="2"
                                        Command="{Binding ApplyCommand}" ToolTip.Tip="{Binding Name}">
                                    <Border Background="{Binding PreviewBackground}"
                                            BorderBrush="{Binding PreviewBorder}" BorderThickness="1.5"
                                            CornerRadius="3" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ribbon:RibbonButton Header="Reset" Command="{Binding StylePalette.ResetCommand}"
                                         IconData="{pia:IconGeometry Icon=arrow_counter_clockwise}" />
                    <ribbon:RibbonButton Header="No fill" Command="{Binding StylePalette.NoFillCommand}"
                                         IconData="{StaticResource ToolIcon.NoFill}" />
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>

            <ribbon:RibbonTab Header="Arrange">
                <ribbon:RibbonGroup Header="Align">
                    <ribbon:RibbonDropDownButton x:Name="AlignDropDown" Header="Align"
                                                 IsEnabled="{Binding ActiveDocument.CanAlignSelection}"
                                                 IconData="{pia:IconGeometry Icon=align_left}">
                        <ribbon:RibbonMenuItem Header="Align left" CommandParameter="{x:Static layout:AlignmentMode.Left}" IconData="{pia:IconGeometry Icon=align_left}" />
                        <ribbon:RibbonMenuItem Header="Align center" CommandParameter="{x:Static layout:AlignmentMode.CenterHorizontal}" IconData="{pia:IconGeometry Icon=align_center_horizontal}" />
                        <ribbon:RibbonMenuItem Header="Align right" CommandParameter="{x:Static layout:AlignmentMode.Right}" IconData="{pia:IconGeometry Icon=align_right}" />
                        <ribbon:RibbonMenuItem Header="Align top" CommandParameter="{x:Static layout:AlignmentMode.Top}" IconData="{pia:IconGeometry Icon=align_top}" />
                        <ribbon:RibbonMenuItem Header="Align middle" CommandParameter="{x:Static layout:AlignmentMode.CenterVertical}" IconData="{pia:IconGeometry Icon=align_center_vertical}" />
                        <ribbon:RibbonMenuItem Header="Align bottom" CommandParameter="{x:Static layout:AlignmentMode.Bottom}" IconData="{pia:IconGeometry Icon=align_bottom}" />
                    </ribbon:RibbonDropDownButton>
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="Reference">
                    <ribbon:RibbonButton Header="Set as reference"
                                         Command="{Binding ActiveDocument.SetReferenceCommand}"
                                         IconData="{pia:IconGeometry Icon=push_pin}" />
                    <ribbon:RibbonDropDownButton x:Name="AlignToReferenceDropDown" Header="Align to reference"
                                                 IsEnabled="{Binding ActiveDocument.CanAlignToReference}"
                                                 IconData="{pia:IconGeometry Icon=align_center_horizontal}">
                        <ribbon:RibbonMenuItem Header="Align left" CommandParameter="{x:Static layout:AlignmentMode.Left}" IconData="{pia:IconGeometry Icon=align_left}" />
                        <ribbon:RibbonMenuItem Header="Align center" CommandParameter="{x:Static layout:AlignmentMode.CenterHorizontal}" IconData="{pia:IconGeometry Icon=align_center_horizontal}" />
                        <ribbon:RibbonMenuItem Header="Align right" CommandParameter="{x:Static layout:AlignmentMode.Right}" IconData="{pia:IconGeometry Icon=align_right}" />
                        <ribbon:RibbonMenuItem Header="Align top" CommandParameter="{x:Static layout:AlignmentMode.Top}" IconData="{pia:IconGeometry Icon=align_top}" />
                        <ribbon:RibbonMenuItem Header="Align middle" CommandParameter="{x:Static layout:AlignmentMode.CenterVertical}" IconData="{pia:IconGeometry Icon=align_center_vertical}" />
                        <ribbon:RibbonMenuItem Header="Align bottom" CommandParameter="{x:Static layout:AlignmentMode.Bottom}" IconData="{pia:IconGeometry Icon=align_bottom}" />
                    </ribbon:RibbonDropDownButton>
                    <ribbon:RibbonButton Header="Clear reference"
                                         Command="{Binding ActiveDocument.ClearReferenceCommand}"
                                         IconData="{pia:IconGeometry Icon=x}" />
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="Distribute">
                    <ribbon:RibbonButton Header="Distribute H"
                                         Command="{Binding ActiveDocument.DistributeCommand}"
                                         CommandParameter="{x:Static layout:DistributionMode.Horizontal}"
                                         IconData="{StaticResource ToolIcon.DistributeHorizontal}" />
                    <ribbon:RibbonButton Header="Distribute V"
                                         Command="{Binding ActiveDocument.DistributeCommand}"
                                         CommandParameter="{x:Static layout:DistributionMode.Vertical}"
                                         IconData="{StaticResource ToolIcon.DistributeVertical}" />
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="Order">
                    <ribbon:RibbonButton Header="Bring to front"
                                         Command="{Binding ActiveDocument.OrderCommand}"
                                         CommandParameter="{x:Static layout:ZOrderOperation.BringToFront}"
                                         IconData="{StaticResource ToolIcon.BringToFront}" />
                    <ribbon:RibbonButton Header="Bring forward"
                                         Command="{Binding ActiveDocument.OrderCommand}"
                                         CommandParameter="{x:Static layout:ZOrderOperation.BringForward}"
                                         IconData="{StaticResource ToolIcon.BringForward}" />
                    <ribbon:RibbonButton Header="Send backward"
                                         Command="{Binding ActiveDocument.OrderCommand}"
                                         CommandParameter="{x:Static layout:ZOrderOperation.SendBackward}"
                                         IconData="{StaticResource ToolIcon.SendBackward}" />
                    <ribbon:RibbonButton Header="Send to back"
                                         Command="{Binding ActiveDocument.OrderCommand}"
                                         CommandParameter="{x:Static layout:ZOrderOperation.SendToBack}"
                                         IconData="{StaticResource ToolIcon.SendToBack}" />
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="Connections">
                    <ribbon:RibbonButton Header="Space connections"
                                         Command="{Binding ActiveDocument.SpaceConnectionsCommand}"
                                         IconData="{StaticResource ToolIcon.SpaceConnections}" />
                    <ribbon:RibbonButton Header="Merge connections"
                                         Command="{Binding ActiveDocument.MergeConnectionsCommand}"
                                         IconData="{StaticResource ToolIcon.MergeConnections}" />
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>

            <ribbon:RibbonTab Header="View">
                <ribbon:RibbonGroup Header="Zoom">
                    <ribbon:RibbonButton Header="Zoom In" Command="{Binding ActiveDocument.ZoomInCommand}" IconData="{pia:IconGeometry Icon=magnifying_glass_plus}" />
                    <ribbon:RibbonButton Header="Zoom Out" Command="{Binding ActiveDocument.ZoomOutCommand}" IconData="{pia:IconGeometry Icon=magnifying_glass_minus}" />
                    <ribbon:RibbonButton Header="Reset" Command="{Binding ActiveDocument.ZoomResetCommand}" IconData="{pia:IconGeometry Icon=arrows_out}" />
                    <ribbon:RibbonButton Header="Fit to content" Command="{Binding ActiveDocument.FitToContentCommand}" IconData="{pia:IconGeometry Icon=arrows_in}" />
                </ribbon:RibbonGroup>
                <ribbon:RibbonGroup Header="Appearance">
                    <ribbon:RibbonButton Header="Toggle theme" Command="{Binding ToggleThemeCommand}" IconData="{pia:IconGeometry Icon=moon}" />
                    <!-- Self-toggles IsChecked on click; binding writes it back to the VM (no Command, or it
                         would toggle twice). Stays in sync with the menu item / panel chevron via TwoWay. -->
                    <ribbon:RibbonToggleButton Header="Properties"
                                               IconData="{pia:IconGeometry Icon=sidebar}"
                                               IsChecked="{Binding IsInspectorOpen, Mode=TwoWay}" />
                    <!-- Self-toggles like Properties above; TwoWay writes back to the shared editor options,
                         so snapping turns on/off for every open document at once. -->
                    <ribbon:RibbonToggleButton Header="Snap to grid"
                                               IconData="{pia:IconGeometry Icon=grid_four}"
                                               IsChecked="{Binding SnapToGrid, Mode=TwoWay}" />
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>
        </ribbon:Ribbon>

        <Border DockPanel.Dock="Bottom" Background="{DynamicResource CarbonSurfaceBrush}"
                BorderBrush="{DynamicResource CarbonBorderBrush}" BorderThickness="0,1,0,0" Padding="8,3">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding ActiveDocument.DisplayName, FallbackValue='No document'}" />
                <TextBlock Text="{Binding ActiveDocument.Zoom, StringFormat='Zoom: {0:P0}', FallbackValue=''}" />
                <TextBlock Text="{Binding Toolbox.ActiveToolHint}" FontWeight="SemiBold" />
                <!-- Keyboard chord feedback: the pending key sequence or a transient message. -->
                <TextBlock Text="{Binding KeymapStatus.Display}" FontWeight="SemiBold" Opacity="0.8" />
            </StackPanel>
        </Border>

        <Grid x:Name="EditorGrid">
            <Grid.ColumnDefinitions>
                <!-- Canvas: MinWidth keeps the splitter from dragging it down to nothing. -->
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="Auto" />
                <!-- Inspector: resizable via the splitter; MinWidth keeps the fixed-width member rows
                     from clipping. No MaxWidth — the user can widen it freely (bounded only by the
                     canvas MinWidth). -->
                <ColumnDefinition Width="520" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- Document tabs -->
            <TabControl Grid.Column="0"
                        ItemsSource="{Binding Documents}"
                        SelectedItem="{Binding ActiveDocument, Mode=TwoWay}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DiagramDocumentViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                            <Button Padding="4,0"
                                    Background="Transparent" BorderThickness="0"
                                    Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).CloseDocumentCommand}"
                                    CommandParameter="{Binding}">
                                <PathIcon Data="{pia:IconGeometry Icon=x}" Width="9" Height="9" />
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:DiagramDocumentViewModel">
                        <v:DiagramView />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <!-- Drag handle between canvas and inspector. Sits in the Auto column and doubles
                 as the divider, so the inspector border drops its left edge below. Hidden when the
                 inspector is collapsed — resizing a strip is meaningless. -->
            <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                          IsVisible="{Binding IsInspectorOpen}"
                          Background="{DynamicResource CarbonBorderBrush}" />

            <!-- Inspector. Two states overlap in a Panel: a thin re-open strip when collapsed, and the
                 full panel when open. The collapse width/splitter are driven from code-behind (see
                 ApplyInspectorState) so the splitter-resized width survives a collapse/reopen. -->
            <Border Grid.Column="2" Background="{DynamicResource CarbonSurfaceBrush}">
                <Panel>
                    <!-- Collapsed: thin strip with a re-open chevron pinned to the top. -->
                    <Border Width="32" IsVisible="{Binding IsInspectorCollapsed}">
                        <Button VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,8,0,0"
                                Padding="4" Background="Transparent" BorderThickness="0"
                                ToolTip.Tip="Show properties"
                                Command="{Binding ToggleInspectorCommand}">
                            <PathIcon Data="{pia:IconGeometry Icon=caret_left}" Width="12" Height="12" />
                        </Button>
                    </Border>

                    <!-- Open: fixed header (title + collapse chevron) above the scrollable properties. -->
                    <DockPanel IsVisible="{Binding IsInspectorOpen}">
                        <Grid DockPanel.Dock="Top" Margin="10,10,10,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Properties" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Padding="4" Background="Transparent" BorderThickness="0"
                                    ToolTip.Tip="Hide properties"
                                    Command="{Binding ToggleInspectorCommand}">
                                <PathIcon Data="{pia:IconGeometry Icon=caret_right}" Width="12" Height="12" />
                            </Button>
                        </Grid>
                <ScrollViewer Padding="10,0,10,10">
                    <!-- Right margin reserves a gutter for the vertical scrollbar (Avalonia overlays it
                         on the content edge, otherwise it covers the fields / row remove buttons). -->
                    <StackPanel Spacing="10" Margin="0,0,14,0">
                        <TextBlock Text="No selection" Opacity="0.6"
                                   IsVisible="{Binding Inspector.HasNoSelection}" />

                        <!-- Label (all label-bearing nodes) -->
                        <StackPanel Spacing="10" IsVisible="{Binding Inspector.IsLabelNodeSelected}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Text" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.Text, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" AcceptsReturn="True" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Shared node style (shapes and class nodes) -->
                        <StackPanel Spacing="10" IsVisible="{Binding Inspector.IsNodeSelected}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Fill (#AARRGGBB)" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.FillHex, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                            <StackPanel Spacing="3">
                                <TextBlock Text="Stroke (#AARRGGBB)" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.StrokeHex, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                            <StackPanel Spacing="3">
                                <TextBlock Text="Stroke thickness" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.StrokeThickness, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                            <StackPanel Spacing="3">
                                <TextBlock Text="Font size" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.FontSize, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <CheckBox Content="Bold" IsChecked="{Binding Inspector.Bold, Mode=TwoWay}" />
                                <CheckBox Content="Italic" IsChecked="{Binding Inspector.Italic, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Spacing="3">
                                <TextBlock Text="Text alignment" Opacity="0.7" />
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Static vm:InspectorViewModel.AlignmentOptions}"
                                          SelectedItem="{Binding Inspector.Alignment, Mode=TwoWay}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Class node properties -->
                        <StackPanel IsVisible="{Binding Inspector.IsClassNodeSelected}">
                        <StackPanel Spacing="10" DataContext="{Binding Inspector.SelectedClassNode}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Name" Opacity="0.7" />
                                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                            <CheckBox Content="Abstract" IsChecked="{Binding IsAbstract, Mode=TwoWay}" />

                            <!-- Members: tidy aligned editor. Add lives in the header; each row aligns its
                                 columns via shared-size groups. -->
                            <StackPanel Grid.IsSharedSizeScope="True">
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                    <TextBlock Text="Members" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Button ToolTip.Tip="Add field/literal"
                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.AddPrimaryMemberCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <PathIcon Data="{pia:IconGeometry Icon=plus}" Width="10" Height="10" />
                                            <TextBlock Text="Field" />
                                        </StackPanel>
                                    </Button>
                                    <Button IsVisible="{Binding HasOperations}" ToolTip.Tip="Add operation"
                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.AddOperationCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <PathIcon Data="{pia:IconGeometry Icon=plus}" Width="10" Height="10" />
                                            <TextBlock Text="Op" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding PrimaryMembers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ClassMemberViewModel">
                                            <Grid ColumnSpacing="3" Margin="0,0,0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="PVis" />
                                                    <ColumnDefinition Width="*" MinWidth="40" />
                                                    <ColumnDefinition Width="*" MinWidth="40" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="PAct" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" MinWidth="52"
                                                          ItemsSource="{x:Static vm:InspectorViewModel.VisibilityOptions}"
                                                          SelectedItem="{Binding Visibility, Mode=TwoWay}" />
                                                <TextBox Grid.Column="1" PlaceholderText="name"
                                                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <AutoCompleteBox Grid.Column="2" PlaceholderText="type"
                                                                 ItemsSource="{Binding TypeSuggestions}"
                                                                 Text="{Binding Type, Mode=TwoWay}" />
                                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Move up"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.MoveMemberUpCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=caret_up}" Width="9" Height="9" />
                                                    </Button>
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Move down"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.MoveMemberDownCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=caret_down}" Width="9" Height="9" />
                                                    </Button>
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Remove"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.RemoveMemberCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=x}" Width="9" Height="9" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Operations" Opacity="0.7" Margin="0,4,0,2" IsVisible="{Binding HasOperations}" />
                                <ItemsControl ItemsSource="{Binding Operations}" IsVisible="{Binding HasOperations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ClassMemberViewModel">
                                            <Grid ColumnSpacing="3" Margin="0,0,0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="PVis" />
                                                    <ColumnDefinition Width="*" MinWidth="40" />
                                                    <ColumnDefinition Width="*" MinWidth="40" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="PAct" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" MinWidth="52"
                                                          ItemsSource="{x:Static vm:InspectorViewModel.VisibilityOptions}"
                                                          SelectedItem="{Binding Visibility, Mode=TwoWay}" />
                                                <TextBox Grid.Column="1" PlaceholderText="name"
                                                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <AutoCompleteBox Grid.Column="2" PlaceholderText="ret"
                                                                 ItemsSource="{Binding TypeSuggestions}"
                                                                 Text="{Binding Type, Mode=TwoWay}" />
                                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Move up"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.MoveMemberUpCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=caret_up}" Width="9" Height="9" />
                                                    </Button>
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Move down"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.MoveMemberDownCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=caret_down}" Width="9" Height="9" />
                                                    </Button>
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Remove"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.RemoveMemberCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=x}" Width="9" Height="9" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>

                        <!-- Entity (ER table) properties -->
                        <StackPanel IsVisible="{Binding Inspector.IsEntityNodeSelected}">
                        <StackPanel Spacing="10" DataContext="{Binding Inspector.SelectedEntityNode}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Table name" Opacity="0.7" />
                                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <!-- Columns: each row inlines name, type, the PK/FK/Null/Uniq flags and
                                 reorder/remove, aligned across rows via shared-size groups (like members). -->
                            <StackPanel Grid.IsSharedSizeScope="True">
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                    <TextBlock Text="Columns" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Button ToolTip.Tip="Add column"
                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.AddColumnCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <PathIcon Data="{pia:IconGeometry Icon=plus}" Width="10" Height="10" />
                                            <TextBlock Text="Column" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding Columns}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:EntityColumnViewModel">
                                            <Grid ColumnSpacing="3" Margin="0,0,0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" MinWidth="40" />
                                                    <ColumnDefinition Width="*" MinWidth="40" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CPk" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CFk" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CNull" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CUniq" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CAct" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" PlaceholderText="name"
                                                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <AutoCompleteBox Grid.Column="1" PlaceholderText="type"
                                                                 ItemsSource="{Binding TypeSuggestions}"
                                                                 Text="{Binding Type, Mode=TwoWay}" />
                                                <CheckBox Grid.Column="2" Content="PK" VerticalAlignment="Center" IsChecked="{Binding IsPrimaryKey, Mode=TwoWay}" />
                                                <CheckBox Grid.Column="3" Content="FK" VerticalAlignment="Center" IsChecked="{Binding IsForeignKey, Mode=TwoWay}" />
                                                <CheckBox Grid.Column="4" Content="Null" VerticalAlignment="Center" IsChecked="{Binding IsNullable, Mode=TwoWay}" />
                                                <CheckBox Grid.Column="5" Content="Uniq" VerticalAlignment="Center" IsChecked="{Binding IsUnique, Mode=TwoWay}" />
                                                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Move up"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.MoveColumnUpCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=caret_up}" Width="9" Height="9" />
                                                    </Button>
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Move down"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.MoveColumnDownCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=caret_down}" Width="9" Height="9" />
                                                    </Button>
                                                    <Button Padding="3" MinWidth="0" ToolTip.Tip="Remove"
                                                            Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).Inspector.RemoveColumnCommand}"
                                                            CommandParameter="{Binding}">
                                                        <PathIcon Data="{pia:IconGeometry Icon=x}" Width="9" Height="9" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>

                        <!-- Connector properties -->
                        <StackPanel Spacing="10" IsVisible="{Binding Inspector.IsConnectorSelected}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Relationship" Opacity="0.7" />
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Static vm:InspectorViewModel.RelationshipOptions}"
                                          SelectedItem="{Binding Inspector.ConnectorKind, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Route" Opacity="0.7" />
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Static vm:InspectorViewModel.RouteStyleOptions}"
                                          SelectedItem="{Binding Inspector.ConnectorRouteStyle, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Source cardinality" Opacity="0.7" />
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Static vm:InspectorViewModel.CardinalityOptions}"
                                          SelectedItem="{Binding Inspector.SourceCardinality, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Target cardinality" Opacity="0.7" />
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Static vm:InspectorViewModel.CardinalityOptions}"
                                          SelectedItem="{Binding Inspector.TargetCardinality, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Source label" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.SourceLabel, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Center label" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.CenterLabel, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Target label" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.TargetLabel, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Stroke (#AARRGGBB)" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.ConnectorStrokeHex, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Stroke thickness" Opacity="0.7" />
                                <TextBox Text="{Binding Inspector.ConnectorThickness, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                    </DockPanel>
                </Panel>
            </Border>
        </Grid>
    </DockPanel>

        <!-- Registered with IContentDialogService at construction; driven by DialogService. -->
        <dialog:ContentDialog x:Name="DialogHost" />
    </Grid>
</Window>
