<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Draw.App.ViewModels"
             xmlns:nodes="using:Draw.Model.Nodes"
             xmlns:views="using:Draw.App.Views"
             xmlns:pia="using:PhosphorIconsAvalonia.Markup"
             x:Class="Draw.App.Views.DiagramView"
             x:DataType="vm:DiagramDocumentViewModel"
             Background="Transparent"
             Focusable="True">

    <UserControl.Resources>
        <!-- Shared inline-edit row for class members, used by both the field and operation
             compartments. The Visibility submenu's !IsEnumLiteral guard is a no-op for operations
             (never enum literals), so a single template serves both. -->
        <DataTemplate x:Key="ClassMemberRowTemplate" x:DataType="vm:ClassMemberViewModel">
            <Panel>
                <Panel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Insert below" Click="OnInsertBelowClick" />
                        <MenuItem Header="Move up" Click="OnMoveMemberUpClick" />
                        <MenuItem Header="Move down" Click="OnMoveMemberDownClick" />
                        <Separator />
                        <MenuItem Header="Visibility" IsVisible="{Binding !IsEnumLiteral}">
                            <MenuItem Header="Public" Tag="{x:Static nodes:MemberVisibility.Public}" Click="OnSetVisibilityClick" />
                            <MenuItem Header="Private" Tag="{x:Static nodes:MemberVisibility.Private}" Click="OnSetVisibilityClick" />
                            <MenuItem Header="Protected" Tag="{x:Static nodes:MemberVisibility.Protected}" Click="OnSetVisibilityClick" />
                            <MenuItem Header="Package" Tag="{x:Static nodes:MemberVisibility.Package}" Click="OnSetVisibilityClick" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Delete" Click="OnRemoveMemberClick" />
                    </ContextMenu>
                </Panel.ContextMenu>
                <TextBlock Text="{Binding DisplayText}" FontSize="11"
                           Foreground="{Binding $parent[ItemsControl].((vm:ClassNodeViewModel)DataContext).Foreground}"
                           FontStyle="{Binding RowFontStyle}"
                           TextDecorations="{Binding RowDecorations}"
                           IsVisible="{Binding !IsEditing}"
                           DoubleTapped="OnMemberDoubleTapped" />
                <TextBox Text="{Binding RawText, Mode=TwoWay}" FontSize="11"
                         Background="Transparent" Padding="0"
                         IsVisible="{Binding IsEditing}"
                         KeyDown="OnMemberEditKeyDown"
                         LostFocus="OnMemberEditCommitted" />
            </Panel>
        </DataTemplate>
    </UserControl.Resources>

    <!-- 2x2 grid: canvas + scrollbar gutters. The Auto row/column collapse to 0 when their
         scrollbar is hidden (content fits), so the canvas reclaims the space. Scrollbar geometry
         and visibility are driven from code-behind (UpdateScrollBars). -->
    <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">

        <Border x:Name="Viewport" Grid.Row="0" Grid.Column="0" ClipToBounds="True" Background="{DynamicResource CanvasBackgroundBrush}">
        <Canvas x:Name="World" RenderTransformOrigin="0,0">

            <Rectangle x:Name="GridBackground"
                       Canvas.Left="-2000" Canvas.Top="-2000"
                       Width="6000" Height="6000"
                       IsHitTestVisible="False" />

            <!-- Nodes and Connectors are unbounded world-space layers. Their Canvas ItemsPanel has
                 zero desired size, so the ItemsControl measures to 0x0; since ItemsControl defaults
                 ClipToBounds=true, it would otherwise clip every item away. Keep it false — the
                 Viewport border above is what actually clips to the visible region. -->
            <ItemsControl x:Name="NodesLayer" ItemsSource="{Binding Nodes}" ClipToBounds="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.Styles>
                    <Style Selector="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{ReflectionBinding X}" />
                        <Setter Property="Canvas.Top" Value="{ReflectionBinding Y}" />
                        <!-- Stacking order: bind the element's own ZIndex (Visual.ZIndex). Avalonia has
                             NO Canvas.ZIndex attached property (unlike WPF's Panel.ZIndex), so the name
                             must be unqualified or it silently no-ops. System boundaries carry a lower
                             ZIndex (reserved band) so they sit behind the nodes they enclose. -->
                        <Setter Property="ZIndex" Value="{ReflectionBinding ZIndex}" />
                    </Style>
                </ItemsControl.Styles>
                <!-- One DataTemplate per NodeViewModelBase subtype. This is the one node-kind site the
                     compiler can't enforce (a missing template renders a fallback string at runtime, not a
                     build error) — keep it in sync with NodeKindRegistry when adding a kind. -->
                <ItemsControl.DataTemplates>
                    <DataTemplate DataType="vm:ShapeNodeViewModel">
                        <Panel Width="{Binding Width}" Height="{Binding Height}">
                            <Path Data="{Binding Geometry}"
                                  Fill="{Binding Fill}"
                                  Stroke="{Binding Stroke}"
                                  StrokeThickness="{Binding StrokeThickness}"
                                  StrokeDashArray="{Binding StrokeDashArray}" />
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{Binding Foreground}"
                                       FontFamily="{Binding FontFamily}"
                                       FontSize="{Binding FontSize}"
                                       FontWeight="{Binding FontWeight}"
                                       FontStyle="{Binding FontStyle}"
                                       TextAlignment="{Binding TextAlignment}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Margin="6"
                                       IsVisible="{Binding !IsEditing}" />
                            <TextBox x:Name="EditBox"
                                     Text="{Binding Text, Mode=TwoWay}"
                                     FontFamily="{Binding FontFamily}"
                                     FontSize="{Binding FontSize}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Background="Transparent"
                                     IsVisible="{Binding IsEditing}" />
                        </Panel>
                    </DataTemplate>

                    <DataTemplate DataType="vm:ClassNodeViewModel">
                        <Panel Width="{Binding Width}" Height="{Binding Height}">
                            <Panel.Styles>
                                <Style Selector="Button.memberAdd">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                    <Setter Property="MinWidth" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Padding" Value="4,0" />
                                    <Setter Property="Margin" Value="0,1,2,0" />
                                    <Setter Property="FontSize" Value="11" />
                                </Style>
                                <Style Selector="Panel:pointerover Button.memberAdd">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="IsHitTestVisible" Value="True" />
                                </Style>
                            </Panel.Styles>
                            <Border Background="{Binding Fill}"
                                    BorderBrush="{Binding Stroke}"
                                    BorderThickness="{Binding BorderThickness}">
                                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Loaded="OnClassBodyLoaded">
                                    <StackPanel Grid.Row="0" Margin="6,4" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Stereotype}" FontSize="10" FontStyle="Italic"
                                                   HorizontalAlignment="Center"
                                                   IsVisible="{Binding HasStereotype}" />
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                   Foreground="{Binding Foreground}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                    <Rectangle Grid.Row="1" Height="1" Fill="{Binding Stroke}" />
                                    <Panel Grid.Row="2" Background="Transparent" Tag="primary"
                                           DoubleTapped="OnCompartmentDoubleTapped">
                                        <ItemsControl ItemsSource="{Binding PrimaryMembers}" Margin="6,2"
                                                      ItemTemplate="{StaticResource ClassMemberRowTemplate}" />
                                        <Button Classes="memberAdd" Content="+" Click="OnAddFieldClick"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                ToolTip.Tip="Add field" />
                                    </Panel>
                                    <Rectangle Grid.Row="3" Height="1" Fill="{Binding Stroke}"
                                               IsVisible="{Binding HasOperations}" />
                                    <Panel Grid.Row="4" Background="Transparent" Tag="operations"
                                           IsVisible="{Binding HasOperations}"
                                           DoubleTapped="OnCompartmentDoubleTapped">
                                        <ItemsControl ItemsSource="{Binding Operations}" Margin="6,2"
                                                      ItemTemplate="{StaticResource ClassMemberRowTemplate}" />
                                        <Button Classes="memberAdd" Content="+" Click="OnAddOperationClick"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                ToolTip.Tip="Add operation" />
                                    </Panel>
                                </Grid>
                            </Border>
                        </Panel>
                    </DataTemplate>

                    <DataTemplate DataType="vm:EntityNodeViewModel">
                        <Panel Width="{Binding Width}" Height="{Binding Height}">
                            <Panel.Styles>
                                <Style Selector="Button.memberAdd">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                    <Setter Property="MinWidth" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Padding" Value="4,0" />
                                    <Setter Property="Margin" Value="0,1,2,0" />
                                    <Setter Property="FontSize" Value="11" />
                                </Style>
                                <Style Selector="Panel:pointerover Button.memberAdd">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="IsHitTestVisible" Value="True" />
                                </Style>
                            </Panel.Styles>
                            <Border Background="{Binding Fill}"
                                    BorderBrush="{Binding Stroke}"
                                    BorderThickness="{Binding BorderThickness}">
                                <Grid RowDefinitions="Auto,Auto,*">
                                    <TextBlock Grid.Row="0" Text="{Binding Name}" FontWeight="Bold"
                                               Foreground="{Binding Foreground}"
                                               Margin="6,4" HorizontalAlignment="Center" />
                                    <Rectangle Grid.Row="1" Height="1" Fill="{Binding Stroke}" />
                                    <Panel Grid.Row="2" Background="Transparent"
                                           DoubleTapped="OnColumnCompartmentDoubleTapped">
                                        <ItemsControl ItemsSource="{Binding Columns}" Margin="6,2">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:EntityColumnViewModel">
                                                    <Panel>
                                                        <Panel.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Primary key" ToggleType="CheckBox" IsChecked="{Binding IsPrimaryKey, Mode=TwoWay}" />
                                                                <MenuItem Header="Foreign key" ToggleType="CheckBox" IsChecked="{Binding IsForeignKey, Mode=TwoWay}" />
                                                                <MenuItem Header="Nullable" ToggleType="CheckBox" IsChecked="{Binding IsNullable, Mode=TwoWay}" />
                                                                <MenuItem Header="Unique" ToggleType="CheckBox" IsChecked="{Binding IsUnique, Mode=TwoWay}" />
                                                                <Separator />
                                                                <MenuItem Header="Insert below" Click="OnInsertColumnBelowClick" />
                                                                <MenuItem Header="Move up" Click="OnMoveColumnUpClick" />
                                                                <MenuItem Header="Move down" Click="OnMoveColumnDownClick" />
                                                                <Separator />
                                                                <MenuItem Header="Delete" Click="OnRemoveColumnClick" />
                                                            </ContextMenu>
                                                        </Panel.ContextMenu>
                                                        <TextBlock Text="{Binding DisplayText}" FontSize="11"
                                                                   Foreground="{Binding $parent[ItemsControl].((vm:EntityNodeViewModel)DataContext).Foreground}"
                                                                   FontWeight="{Binding RowFontWeight}"
                                                                   TextDecorations="{Binding RowDecorations}"
                                                                   IsVisible="{Binding !IsEditing}"
                                                                   DoubleTapped="OnColumnDoubleTapped" />
                                                        <TextBox Text="{Binding RawText, Mode=TwoWay}" FontSize="11"
                                                                 Background="Transparent" Padding="0"
                                                                 IsVisible="{Binding IsEditing}"
                                                                 KeyDown="OnColumnEditKeyDown"
                                                                 LostFocus="OnColumnEditCommitted" />
                                                    </Panel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Classes="memberAdd" Content="+" Click="OnAddColumnClick"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                ToolTip.Tip="Add column" />
                                    </Panel>
                                </Grid>
                            </Border>
                        </Panel>
                    </DataTemplate>

                    <DataTemplate DataType="vm:ActorNodeViewModel">
                        <Panel Width="{Binding Width}" Height="{Binding Height}">
                            <Path Data="{Binding Geometry}"
                                  Stroke="{Binding Stroke}"
                                  StrokeThickness="{Binding StrokeThickness}" />
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{Binding Foreground}"
                                       FontFamily="{Binding FontFamily}"
                                       FontSize="{Binding FontSize}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Stretch"
                                       IsVisible="{Binding !IsEditing}" />
                            <TextBox Text="{Binding Label, Mode=TwoWay}"
                                     FontSize="{Binding FontSize}"
                                     VerticalAlignment="Bottom"
                                     Background="Transparent"
                                     IsVisible="{Binding IsEditing}" />
                        </Panel>
                    </DataTemplate>

                    <DataTemplate DataType="vm:UseCaseNodeViewModel">
                        <Panel Width="{Binding Width}" Height="{Binding Height}">
                            <Path Data="{Binding Geometry}"
                                  Fill="{Binding Fill}"
                                  Stroke="{Binding Stroke}"
                                  StrokeThickness="{Binding StrokeThickness}" />
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{Binding Foreground}"
                                       FontFamily="{Binding FontFamily}"
                                       FontSize="{Binding FontSize}"
                                       FontWeight="{Binding FontWeight}"
                                       FontStyle="{Binding FontStyle}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Margin="10"
                                       IsVisible="{Binding !IsEditing}" />
                            <TextBox Text="{Binding Label, Mode=TwoWay}"
                                     FontSize="{Binding FontSize}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalAlignment="Center" Background="Transparent"
                                     IsVisible="{Binding IsEditing}" />
                        </Panel>
                    </DataTemplate>

                    <DataTemplate DataType="vm:ImageNodeViewModel">
                        <Panel Width="{Binding Width}" Height="{Binding Height}">
                            <!-- Aspect ratio is locked by the resize gesture, so the bounds already match
                                 the image; Stretch=Fill then never distorts it. -->
                            <Image Source="{Binding Image}" Stretch="Fill" />
                        </Panel>
                    </DataTemplate>

                    <DataTemplate DataType="vm:SystemBoundaryNodeViewModel">
                        <Panel Width="{Binding Width}" Height="{Binding Height}">
                            <Border Background="{Binding Fill}"
                                    BorderBrush="{Binding Stroke}"
                                    BorderThickness="{Binding BorderThickness}" />
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{Binding Foreground}"
                                       FontFamily="{Binding FontFamily}"
                                       FontSize="{Binding FontSize}"
                                       FontWeight="Bold"
                                       Margin="6,4"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       IsVisible="{Binding !IsEditing}" />
                            <TextBox Text="{Binding Label, Mode=TwoWay}"
                                     FontSize="{Binding FontSize}"
                                     Margin="4,2"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Background="Transparent"
                                     IsVisible="{Binding IsEditing}" />
                        </Panel>
                    </DataTemplate>
                </ItemsControl.DataTemplates>
            </ItemsControl>

            <!-- Connectors render on top of every node (highest Z among diagram content) so an edge
                 is never hidden by a filled node such as a System Boundary. The layer is
                 non-hit-testable, so node interaction is unaffected. ClipToBounds=false for the same
                 reason as the node layer above. -->
            <ItemsControl x:Name="ConnectorsLayer" ItemsSource="{Binding Connectors}" IsHitTestVisible="False" ClipToBounds="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ConnectorViewModel">
                        <Canvas>
                            <Path Data="{Binding Geometry}" Stretch="None"
                                  Stroke="{x:Static views:DiagramView.SelectionHaloBrush}" StrokeThickness="6"
                                  IsVisible="{Binding IsSelected}" />
                            <Path Data="{Binding Geometry}" Stretch="None"
                                  Stroke="{Binding Stroke}"
                                  StrokeThickness="{Binding StrokeThickness}"
                                  StrokeDashArray="{Binding StrokeDashArray}" />
                            <Path Data="{Binding SourceDecoration}" Stretch="None"
                                  Stroke="{Binding Stroke}"
                                  StrokeThickness="{Binding StrokeThickness}"
                                  Fill="{Binding SourceDecorationFill}" />
                            <Path Data="{Binding TargetDecoration}" Stretch="None"
                                  Stroke="{Binding Stroke}"
                                  StrokeThickness="{Binding StrokeThickness}"
                                  Fill="{Binding TargetDecorationFill}" />
                            <TextBlock Text="{Binding CenterLabelText}" FontSize="11"
                                       Foreground="{Binding LabelForeground}"
                                       Canvas.Left="{Binding CenterLabelX}" Canvas.Top="{Binding CenterLabelY}"
                                       IsVisible="{Binding HasCenterLabel}" />
                            <TextBlock Text="{Binding SourceLabelText}" FontSize="11"
                                       Foreground="{Binding LabelForeground}"
                                       Canvas.Left="{Binding SourceLabelX}" Canvas.Top="{Binding SourceLabelY}"
                                       IsVisible="{Binding HasSourceLabel}" />
                            <TextBlock Text="{Binding TargetLabelText}" FontSize="11"
                                       Foreground="{Binding LabelForeground}"
                                       Canvas.Left="{Binding TargetLabelX}" Canvas.Top="{Binding TargetLabelY}"
                                       IsVisible="{Binding HasTargetLabel}" />
                        </Canvas>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Canvas x:Name="Overlay" IsHitTestVisible="False" />
        </Canvas>
        </Border>

        <!-- Alignment-reference banner: shown only while a reference is captured. Floats at the top of
             the canvas cell (screen-space, not zoomed); bound to the document VM. -->
        <Border Grid.Row="0" Grid.Column="0"
                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                IsVisible="{Binding HasReference}"
                Background="{DynamicResource CarbonSurfaceBrush}"
                BorderBrush="{DynamicResource CarbonBorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{x:Static views:DiagramView.ReferenceAccentBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ReferenceStatusText}" VerticalAlignment="Center" />
                <Button Content="Clear reference" Command="{Binding ClearReferenceCommand}" Padding="8,2" />
            </StackPanel>
        </Border>

        <ScrollBar x:Name="VScroll" Grid.Row="0" Grid.Column="1"
                   Orientation="Vertical" AllowAutoHide="False" IsVisible="False" />
        <ScrollBar x:Name="HScroll" Grid.Row="1" Grid.Column="0"
                   Orientation="Horizontal" AllowAutoHide="False" IsVisible="False" />

        <!-- Fit-to-content button in the corner where the bars meet (visible only when both show). -->
        <Button x:Name="FitCorner" Grid.Row="1" Grid.Column="1"
                Command="{Binding FitToContentCommand}"
                IsVisible="False" Padding="2"
                Background="Transparent" BorderThickness="0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                ToolTip.Tip="Fit to content (Ctrl+Shift+F)">
            <PathIcon Data="{pia:IconGeometry Icon=arrows_in}" Width="12" Height="12" />
        </Button>
    </Grid>
</UserControl>
