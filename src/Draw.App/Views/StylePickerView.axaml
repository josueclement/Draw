<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Draw.App.ViewModels"
             x:Class="Draw.App.Views.StylePickerView"
             x:DataType="vm:StylePickerViewModel"
             IsVisible="{Binding IsOpen}">

    <!-- Full-window dim backdrop; a press anywhere on it dismisses the picker. Mirrors ToolPaletteView. -->
    <Border Background="#80000000" PointerPressed="OnBackdropPressed">

        <Border PointerPressed="OnPanelPressed"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="520" MaxWidth="760" Padding="18"
                CornerRadius="10" BorderThickness="1"
                Background="{DynamicResource CarbonSurfaceBrush}"
                BorderBrush="{DynamicResource CarbonBorderBrush}"
                BoxShadow="0 12 32 0 #50000000">
            <StackPanel Spacing="14">

                <!-- Heading + usage hint. -->
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Opacity="0.6" FontSize="12"
                               Text="Press a letter to apply · Esc to close" />
                </StackPanel>

                <!-- Swatch tiles: letter chip + colour face + name. -->
                <ItemsControl ItemsSource="{Binding Swatches}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:StyleSwatchEntry">
                            <Button Click="OnSwatchClick" Margin="4" Padding="8"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="20" Height="20" CornerRadius="4" VerticalAlignment="Center"
                                            Background="{DynamicResource CarbonBackgroundBrush}">
                                        <TextBlock Text="{Binding LetterText}" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Width="18" Height="18" CornerRadius="4" BorderThickness="1"
                                            VerticalAlignment="Center"
                                            Background="{Binding Swatch.PreviewBackground}"
                                            BorderBrush="{Binding Swatch.PreviewBorder}" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Non-swatch actions: Reset and No-fill. -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OnResetClick" Padding="8" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="20" Height="20" CornerRadius="4" VerticalAlignment="Center"
                                    Background="{DynamicResource CarbonBackgroundBrush}">
                                <TextBlock Text="{Binding ResetEntry.LetterText}" FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding ResetEntry.Name}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnNoFillClick" Padding="8" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="20" Height="20" CornerRadius="4" VerticalAlignment="Center"
                                    Background="{DynamicResource CarbonBackgroundBrush}">
                                <TextBlock Text="{Binding NoFillEntry.LetterText}" FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding NoFillEntry.Name}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Border>
    </Border>
</UserControl>
