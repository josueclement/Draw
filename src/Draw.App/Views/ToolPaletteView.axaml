<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Draw.App.ViewModels"
             x:Class="Draw.App.Views.ToolPaletteView"
             x:DataType="vm:ToolPaletteViewModel"
             IsVisible="{Binding IsOpen}">

    <!-- Full-window dim backdrop; a press anywhere on it dismisses the palette. When IsOpen is false the
         whole control is collapsed, so it never blocks the editor. -->
    <Border Background="#80000000" PointerPressed="OnBackdropPressed">

        <!-- Centered card. The ItemsPanels below are UniformGrids (not a Canvas), so the Avalonia-12
             ItemsControl+Canvas ClipToBounds trap does not apply here — no ClipToBounds override needed. -->
        <Border PointerPressed="OnPanelPressed"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="520" MaxWidth="760" Padding="18"
                CornerRadius="10" BorderThickness="1"
                Background="{DynamicResource CarbonSurfaceBrush}"
                BorderBrush="{DynamicResource CarbonBorderBrush}"
                BoxShadow="0 12 32 0 #50000000">
            <StackPanel Spacing="14">

                <!-- Breadcrumb heading + usage hint. -->
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Opacity="0.6" FontSize="12"
                               Text="Press a letter to choose · Esc to go back" />
                </StackPanel>

                <!-- Screen 1: categories. -->
                <ItemsControl ItemsSource="{Binding Categories}" IsVisible="{Binding IsCategoriesScreen}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaletteCategoryEntry">
                            <Button Click="OnCategoryClick" Margin="4" Padding="10,8"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="22" Height="22" CornerRadius="4" VerticalAlignment="Center"
                                            Background="{DynamicResource CarbonBackgroundBrush}">
                                        <TextBlock Text="{Binding LetterText}" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Screen 2: items (letter chip + icon + name). -->
                <ItemsControl ItemsSource="{Binding Items}" IsVisible="{Binding IsItemsScreen}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaletteItemEntry">
                            <Button Click="OnItemClick" Margin="4" Padding="8"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="20" Height="20" CornerRadius="4" VerticalAlignment="Center"
                                            Background="{DynamicResource CarbonBackgroundBrush}">
                                        <TextBlock Text="{Binding LetterText}" FontWeight="Bold" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <PathIcon Data="{Binding Icon}" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>
    </Border>
</UserControl>
